# PHI Expenditure Tracking System - Environment Configuration Example
# Copy this file to `.env` or `scripts/.env` and populate secure values.

## Database Configuration
POSTGRES_USER=phi_admin
POSTGRES_PASSWORD=change_this_postgres_password
POSTGRES_DB=expenditures
POSTGRES_PORT=5432

## Flask Configuration
FLASK_SECRET_KEY=change_this_flask_secret_key
FLASK_DEBUG=false
DEMO_MODE=false
DASHBOARD_PORT=5000

## GCP Configuration
GCP_PROJECT_ID=dominion-core-prod
GCP_REGION=us-central1

## GitHub Configuration
GITHUB_TOKEN=ghp_replace_with_github_token

## Security Settings
FORCE_HTTPS=false
RATE_LIMIT_ENABLED=true
SESSION_TIMEOUT=30

## Backup Configuration
BACKUP_RETENTION_DAYS=30

## Feature Flags
ENABLE_AI_OPTIMIZER=true
ENABLE_AUTO_CATEGORIZATION=true

## Resource Monitoring
ALERT_CPU_THRESHOLD=80
ALERT_MEMORY_THRESHOLD=85
ALERT_DISK_THRESHOLD=90
MONITORING_INTERVAL=60
