# PHI Expenditure Tracking System - Environment Configuration (REDACTED)
# NOTE: Sensitive values have been redacted from this file for safety.
# Do NOT commit real secrets. Use `scripts/.env.example` as a template
# and store real secrets in a secret manager or in a local, ignored file.

## Database Configuration
POSTGRES_USER=phi_admin
POSTGRES_PASSWORD=REDACTED
POSTGRES_DB=expenditures
POSTGRES_PORT=5432

## Flask Configuration
FLASK_SECRET_KEY=REDACTED
FLASK_DEBUG=false
DEMO_MODE=false
DASHBOARD_PORT=5000

## GCP Configuration
GCP_PROJECT_ID=dominion-core-prod
GCP_REGION=us-central1

## GitHub Configuration
GITHUB_TOKEN=REDACTED

## Security Settings
FORCE_HTTPS=false
RATE_LIMIT_ENABLED=true
SESSION_TIMEOUT=30

## Backup Configuration
BACKUP_RETENTION_DAYS=30

## Feature Flags
ENABLE_AI_OPTIMIZER=true
ENABLE_AUTO_CATEGORIZATION=true

## Resource Monitoring
ALERT_CPU_THRESHOLD=80
ALERT_MEMORY_THRESHOLD=85
ALERT_DISK_THRESHOLD=90
MONITORING_INTERVAL=60
