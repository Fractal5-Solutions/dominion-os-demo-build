# MCP Servers Environment Configuration Template
# Copy this file to .env.mcp and fill in your credentials
# DO NOT commit the actual .env.mcp file with real credentials!

# =============================================================================
# ATLASSIAN (Jira & Confluence)
# =============================================================================
# Get token from: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_API_TOKEN=your_atlassian_api_token_here
ATLASSIAN_BASE_URL=https://your-domain.atlassian.net

# =============================================================================
# GITHUB
# =============================================================================
# Get token from: https://github.com/settings/tokens
# Required scopes: repo, read:org, read:user, workflow
GITHUB_TOKEN=ghp_your_github_token_here

# =============================================================================
# STRIPE
# =============================================================================
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# =============================================================================
# FIGMA
# =============================================================================
# Get token from: https://www.figma.com/developers/api#access-tokens
FIGMA_API_TOKEN=your_figma_personal_access_token_here

# =============================================================================
# AZURE (for AKS MCP Server)
# =============================================================================
# Get from: https://portal.azure.com
AZURE_SUBSCRIPTION_ID=your_azure_subscription_id
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret

# =============================================================================
# GENERAL CONFIGURATION
# =============================================================================
NODE_ENV=production
LOG_LEVEL=info
ENABLE_METRICS=true
METRICS_PORT=9323

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================
COMPOSE_PROJECT_NAME=mcp-servers
COMPOSE_HTTP_TIMEOUT=120
DOCKER_CLIENT_TIMEOUT=120

# =============================================================================
# MONITORING
# =============================================================================
PROMETHEUS_RETENTION=15d
GRAFANA_ADMIN_PASSWORD=changeme_to_secure_password
