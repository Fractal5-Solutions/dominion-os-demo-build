    "optimization_settings": {
      "response_time_target_ms": 100,
      "uptime_target_percent": 99.999,
      "cpu_usage_limit_percent": 80,
      "memory_usage_limit_percent": 85,
      "disk_usage_limit_percent": 90
    }
  }
}
