[Unit]
Description=Gunicorn OAuth Server
After=network.target

[Service]
User=vscode
Group=vscode
WorkingDirectory=/workspaces/dominion-os-demo-build/oauth_server
ExecStart=/workspaces/dominion-os-demo-build/.venv/bin/gunicorn -w 4 --timeout 60 --log-level info -b 127.0.0.1:5000 app:app
Restart=always
RestartSec=5
LimitNOFILE=4096
Environment="PYTHONUNBUFFERED=1"
StandardOutput=file:/workspaces/dominion-os-demo-build/oauth_server/gunicorn.out.log
StandardError=file:/workspaces/dominion-os-demo-build/oauth_server/gunicorn.err.log

[Install]
WantedBy=multi-user.target
