{
  // ═══════════════════════════════════════════════════════════════
  // PHI DOMINION OS COMMAND CENTER - OPTIMAL VS CODE CONFIGURATION
  // Sovereignty Level: 9/9 | Optimized for Live Operations
  // ═══════════════════════════════════════════════════════════════

  // ─────────────────────────────────────────────────────────────────
  // Editor: Core Settings
  // ─────────────────────────────────────────────────────────────────
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": true,
  "editor.renderWhitespace": "boundary",
  "editor.rulers": [80, 120],
  "editor.wordWrap": "on",
  "editor.minimap.enabled": true,
  "editor.minimap.renderCharacters": false,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.inlineSuggest.enabled": true,
  "editor.suggestSelection": "first",
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": true
  },

  // ─────────────────────────────────────────────────────────────────
  // Files: Management & Exclusions
  // ─────────────────────────────────────────────────────────────────
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.encoding": "utf8",
  "files.eol": "\n",
  "files.exclude": {
    "**/.git": false,
    "**/.mypy_cache": true,
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/.coverage": true,
    "**/node_modules": true,
    "**/venv": true,
    "**/.venv": true,
    "**/.venv_*": true,
    "**/dist": true,
    "**/build": true,
    "**/*.egg-info": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.mypy_cache/**": true,
    "**/__pycache__/**": true,
    "**/node_modules/**": true,
    "**/venv/**": true,
    "**/.venv/**": true,
    "**/.venv_*/**": true,
    "**/dist/**": true,
    "**/build/**": true
  },

  // ─────────────────────────────────────────────────────────────────
  // Search: Optimized for Codebase Navigation
  // ─────────────────────────────────────────────────────────────────
  "search.exclude": {
    "**/.git": true,
    "**/.mypy_cache": true,
    "**/__pycache__": true,
    "**/node_modules": true,
    "**/venv": true,
    "**/.venv": true,
    "**/.venv_*": true,
    "**/dist": true,
    "**/build": true,
    "**/*.log": false,
    "**/telemetry/*.log": false
  },
  "search.followSymlinks": false,
  "search.smartCase": true,
  "search.useIgnoreFiles": true,

  // ─────────────────────────────────────────────────────────────────
  // Python: Language-Specific Settings
  // ─────────────────────────────────────────────────────────────────
  "python.defaultInterpreterPath": "${workspaceFolder}/scripts/.venv/bin/python",
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.extraPaths": [
    "${workspaceFolder}",
    "${workspaceFolder}/scripts"
  ],
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": false,
  "python.linting.flake8Enabled": true,
  "python.linting.mypyEnabled": true,
  "python.formatting.provider": "black",
  "python.formatting.blackArgs": ["--line-length", "88"],
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": [
    "."
  ],

  // ─────────────────────────────────────────────────────────────────
  // Shell Scripts: Bash/Shell Configuration
  // ─────────────────────────────────────────────────────────────────
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format",
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "shellformat.flag": "-i 2 -ci",

  // ─────────────────────────────────────────────────────────────────
  // JSON: Configuration Files
  // ─────────────────────────────────────────────────────────────────
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.tabSize": 2,
    "editor.quickSuggestions": {
      "strings": true
    }
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.tabSize": 2
  },

  // ─────────────────────────────────────────────────────────────────
  // Markdown: Documentation
  // ─────────────────────────────────────────────────────────────────
  "[markdown]": {
    "editor.defaultFormatter": "yzhang.markdown-all-in-one",
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "other": true,
      "comments": true,
      "strings": true
    }
  },
  "markdown.preview.breaks": true,
  "markdown.preview.linkify": true,

  // ─────────────────────────────────────────────────────────────────
  // YAML: Configuration Files
  // ─────────────────────────────────────────────────────────────────
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "yaml.schemas": {
    "https://json.schemastore.org/github-workflow.json": ".github/workflows/*.yml"
  },

  // ─────────────────────────────────────────────────────────────────
  // Git: Version Control
  // ─────────────────────────────────────────────────────────────────
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.postCommitCommand": "none",
  "git.showPushSuccessNotification": true,
  "git.decorations.enabled": true,
  "git.ignoreLimitWarning": true,

  // ─────────────────────────────────────────────────────────────────
  // Terminal: Integrated Terminal Settings
  // ─────────────────────────────────────────────────────────────────
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.fontFamily": "monospace",
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.enableBell": false,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",

  // ─────────────────────────────────────────────────────────────────
  // Explorer: File Tree Configuration
  // ─────────────────────────────────────────────────────────────────
  "explorer.confirmDelete": true,
  "explorer.confirmDragAndDrop": false,
  "explorer.sortOrder": "mixed",
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.py": "${capture}.pyc, ${capture}.pyo",
    "*.sh": "${capture}.log",
    "package.json": "package-lock.json, yarn.lock",
    "docker-compose.yml": "docker-compose.*.yml",
    ".gitignore": ".gitattributes, .gitmodules"
  },

  // ─────────────────────────────────────────────────────────────────
  // GitHub Copilot: AI Assistance
  // ─────────────────────────────────────────────────────────────────
  "github.copilot.enable": {
    "*": true,
    "yaml": true,
    "plaintext": false,
    "markdown": true,
    "python": true,
    "shellscript": true
  },
  "github.copilot.editor.enableAutoCompletions": true,

  // ─────────────────────────────────────────────────────────────────
  // Problems: Error & Warning Display
  // ─────────────────────────────────────────────────────────────────
  "problems.decorations.enabled": true,
  "problems.showCurrentInStatus": true,

  // ─────────────────────────────────────────────────────────────────
  // Workbench: UI Configuration
  // ─────────────────────────────────────────────────────────────────
  "workbench.colorTheme": "Default Dark+",
  "workbench.startupEditor": "none",
  "workbench.editor.enablePreview": false,
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.tree.indent": 16,
  "workbench.list.smoothScrolling": true,

  // ─────────────────────────────────────────────────────────────────
  // Security: Workspace Trust
  // ─────────────────────────────────────────────────────────────────
  "security.workspace.trust.untrustedFiles": "prompt",
  "security.workspace.trust.enabled": true,

  // ─────────────────────────────────────────────────────────────────
  // Extensions: Recommended Behavior
  // ─────────────────────────────────────────────────────────────────
  "extensions.autoUpdate": true,
  "extensions.ignoreRecommendations": false,

  // ─────────────────────────────────────────────────────────────────
  // Telemetry: Analytics (Disabled for Privacy)
  // ─────────────────────────────────────────────────────────────────
  "telemetry.telemetryLevel": "off",

  // ─────────────────────────────────────────────────────────────────
  // Docker: Container Development
  // ─────────────────────────────────────────────────────────────────
  "docker.showStartPage": false,

  // ─────────────────────────────────────────────────────────────────
  // Cloud: GCP & Azure Integration
  // ─────────────────────────────────────────────────────────────────
  "cloudcode.autoDependencies": "on",

  // ─────────────────────────────────────────────────────────────────
  // Live Share: Collaboration (if installed)
  // ─────────────────────────────────────────────────────────────────
  "liveshare.presence": true,

  // ─────────────────────────────────────────────────────────────────
  // Command Center: Custom Settings
  // ─────────────────────────────────────────────────────────────────
  "[log]": {
    "editor.wordWrap": "on",
    "editor.fontSize": 12
  }
}
