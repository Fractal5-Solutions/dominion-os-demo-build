{
  "displayName": "Dominion OS - High Error Rate Alert",
  "combiner": "OR",
  "conditions": [
    {
      "displayName": "High 5xx Error Rate",
      "conditionThreshold": {
        "filter": "metric.type=\"logging.googleapis.com/user/http_5xx_errors\" resource.type=\"cloud_run_revision\"",
        "aggregations": [
          {
            "alignmentPeriod": "300s",
            "perSeriesAligner": "ALIGN_RATE"
          }
        ],
        "comparison": "COMPARISON_GT",
        "thresholdValue": 0.01,
        "duration": "300s"
      }
    }
  ],
  "notificationChannels": []
}