[Unit]
Description=Gunicorn Widget Service
After=network.target

[Service]
User=vscode
Group=vscode
WorkingDirectory=/workspaces/dominion-os-demo-build/widget_service
ExecStart=/workspaces/dominion-os-demo-build/.venv/bin/gunicorn -w 4 --timeout 60 --log-level info -b 127.0.0.1:8080 app:app
Restart=always
RestartSec=5
LimitNOFILE=4096
Environment="PYTHONUNBUFFERED=1"
StandardOutput=file:/workspaces/dominion-os-demo-build/widget_service/gunicorn.out.log
StandardError=file:/workspaces/dominion-os-demo-build/widget_service/gunicorn.err.log

[Install]
WantedBy=multi-user.target
