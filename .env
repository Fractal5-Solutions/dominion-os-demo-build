# Project Configuration
PROJECT_ID=dominion-core-prod
REGION=us-central1
ENV=production

# PHI Sovereign Configuration
PHI_MODE=SOVEREIGN_MAX
AUTHORITY_LEVEL=9
SOVEREIGNTY_LEVEL=9/9

# Hardware Configuration
CPU_CORES=6
GPU_ENABLED=true
NVIDIA_VISIBLE_DEVICES=all
CUDA_VISIBLE_DEVICES=0

# Database Configuration
POSTGRES_DB=phi_dominion
POSTGRES_USER=phi_admin
POSTGRES_PASSWORD=IVPsp36/K3hbcmuCd1k1obqaK5/flto27NIIchXyPio=
POSTGRES_HOST=phi-database
POSTGRES_PORT=5432
PGDATA=/var/lib/postgresql/data/pgdata

# Redis Configuration
REDIS_HOST=phi-redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_MAX_MEMORY=512mb

# Application Configuration
FLASK_APP=command_core:app
FLASK_ENV=production
SECRET_KEY=e9e63b524e025d1e5cbbe1a30cb79ee8bf0fb97b43be9db0e465b2c4ce0f83b0
DEBUG=false
DATABASE_URL=postgresql://phi_admin:IVPsp36/K3hbcmuCd1k1obqaK5/flto27NIIchXyPio=@localhost:5432/phi_dominion

# Authentication
OAUTH_CLIENT_ID=your_oauth_client_id
OAUTH_CLIENT_SECRET=your_oauth_client_secret
JWT_SECRET_KEY=8487f6452ebbd2c3784d1c2d8b561ede24022d19bb7c6c38dd3a271c76f748b7

# Billing (Stripe + webhook)
STRIPE_SECRET=sk_live_replace_with_real_key
STRIPE_ENDPOINT_SECRET=whsec_replace_with_real_secret

# MCP Stripe (if using docker-compose-mcp.yml)
STRIPE_SECRET_KEY=sk_live_replace_with_real_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_real_secret

# Monitoring
GRAFANA_PASSWORD=CMeCJjwE5GWnNTWJUOXQHE2O+w4no/7hbf8cZbm6Clg=
PROMETHEUS_RETENTION=7d

# Cloud Configuration (if applicable)
GCP_PROJECT_ID=dominion-core-prod
GCP_REGION=us-central1
GCP_SERVICE_ACCOUNT_KEY_PATH=/secrets/gcp-key.json

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security
HSTS_ENABLED=true
CSP_ENABLED=true
SECURE_HEADERS=true

# Performance
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
