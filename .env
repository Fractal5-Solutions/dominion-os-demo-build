GUNICORN_KEEPALIVE=5

# BIMS Configuration
BIMS_ENABLED=true
BIMS_COMPANIES=fractal5,plane4,bluewave

# Feature Flags
ENABLE_AI_ORCHESTRATION=true
ENABLE_GPU_ACCELERATION=true
ENABLE_SOVEREIGN_MAX=true
ENABLE_PHASE_2_5=true

